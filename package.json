{
	"name": "typenet",
	"private": true,
	"type": "module",
	"module": "index.ts",
	"scripts": {
		"test": "vitest run",
		"test:watch": "vitest",
		"typecheck": "tsc --noEmit",
		"example:xor": "vite-node examples/xor.ts",
		"example:spiral": "vite-node examples/spiral.ts",
		"example:gat": "vite-node examples/gat.ts"
	},
	"dependencies": {
		"hotscript": "^1.0.13",
		"tsover-runtime": "^0.0.7"
	},
	"devDependencies": {
		"@types/node": "^26.1.1",
		"prettier": "^3.5.3",
		"typescript": "npm:tsover@^6.0.2",
		"vite-node": "^6.0.0",
		"vitest": "^4.1.10"
	},
	"prettier": {
		"arrowParens": "avoid",
		"experimentalOperatorPosition": "end",
		"experimentalTernaries": true,
		"printWidth": 60,
		"semi": false,
		"trailingComma": "none",
		"useTabs": false
	}
}
