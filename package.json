{
  "name": "typenet",
  "private": true,
  "type": "module",
  "module": "index.ts",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "example:xor": "vite-node examples/xor.ts",
    "example:spiral": "vite-node examples/spiral.ts",
    "example:gat": "vite-node examples/gat.ts",
    "example:dawn": "vite-node examples/dawn.ts",
    "example:xor:dawn": "vite-node examples/xor-dawn.ts"
  },
  "dependencies": {
    "hotscript": "^1.0.13",
    "tsover-runtime": "^0.0.7",
    "typegpu": "^0.11.9"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@webgpu/types": "^0.1.71",
    "prettier": "^3.5.3",
    "tsover": "npm:tsover-generic-overloads@6.0.2-generic.0",
    "typescript": "npm:tsover-generic-overloads@6.0.2-generic.0",
    "unplugin-typegpu": "^0.11.6",
    "vite-node": "^6.0.0",
    "vitest": "^4.1.10",
    "webgpu": "^0.4.0"
  },
  "prettier": {
    "arrowParens": "avoid",
    "experimentalOperatorPosition": "end",
    "experimentalTernaries": true,
    "printWidth": 60,
    "semi": false,
    "trailingComma": "none",
    "useTabs": false
  }
}
